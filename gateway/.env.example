# Salin file ini ke gateway/.env lalu isi token rahasia

GATEWAY_APP_NAME="Lawangsewu Gateway"
GATEWAY_API_TOKEN="ganti-dengan-token-panjang-dan-acak"

# false = aman (dry-run deploy), true = aktif jalankan rsync deploy
GATEWAY_ALLOW_COMMANDS="false"

# Workspace kode sumber project
GATEWAY_PROJECT_ROOT="/var/www/html/lawangsewu/projects"

# Tujuan deploy lokal
GATEWAY_DEPLOY_ROOT="/var/www/html"

# Lokasi backup terenkripsi
GATEWAY_BACKUP_ROOT="/var/backups/lawangsewu"
