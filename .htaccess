# 1. MENGHILANGKAN EXTENSION .PHP DI URL
RewriteEngine On

# 0a. URL kanonik: pada vhost lawangsewu.pa-semarang.go.id, semua widget harus
# hidup di root domain. Request lama yang masih memakai prefix /lawangsewu/
# diarahkan permanen ke URL root.
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^lawangsewu/(.*)$ /$1 [R=301,L,NC]

# 0. HARDENING: blok akses langsung ke folder/file sensitif
RewriteRule ^(?:scripts|projects|logs|runtime-flags|pasarjohar/php-arsip|pasarjohar/server10/archive|gateway/data)(?:/|$) - [F,L,NC]
RewriteRule (^|/)\.(?!well-known/).* - [F,L,NC]
RewriteRule (^|/)(?:backup\.conf|offsite\.conf|\.env(?:\..*)?)$ - [F,L,NC]

# Blok akses langsung ke proxy shadow internal
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?walkthrough-shadow-proxy\.php[\s?] [NC]
RewriteRule ^walkthrough-shadow-proxy\.php$ - [F,L,NC]
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?widget-directory-shadow-proxy\.php[\s?] [NC]
RewriteRule ^widget-directory-shadow-proxy\.php$ - [F,L,NC]
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?public-widget-shadow-proxy\.php[\s?] [NC]
RewriteRule ^public-widget-shadow-proxy\.php$ - [F,L,NC]
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?landing-shadow-proxy\.php[\s?] [NC]
RewriteRule ^landing-shadow-proxy\.php$ - [F,L,NC]
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?portal-shadow-proxy\.php[\s?] [NC]
RewriteRule ^portal-shadow-proxy\.php$ - [F,L,NC]
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?app-registry-shadow-proxy\.php[\s?] [NC]
RewriteRule ^app-registry-shadow-proxy\.php$ - [F,L,NC]

# Sembunyikan implementasi internal: blok akses URL langsung ke widgets/views
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?widgets/views/ [NC]
RewriteRule ^widgets/views/ - [F,L,NC]

# Legacy URL compatibility for moved HTML files
RewriteRule ^agenda-kegiatan\.html$ widgets/views/agenda-kegiatan.html [L,NC]
RewriteRule ^slide_sidang\.html$ widgets/views/slide_sidang.html [L,NC]

# Public documentation bundle
RewriteCond /var/www/html/lawangsewu/runtime-flags/walkthrough-shadow-on.flag -f
RewriteRule ^walkthrough/?$ walkthrough-shadow-proxy.php [L,NC]
RewriteRule ^walkthrough/?$ Walkthrough-DBPrakom/index.html [L,NC]
RewriteCond /var/www/html/lawangsewu/runtime-flags/widget-directory-shadow-on.flag -f
RewriteRule ^daftar-widget/?$ widget-directory-shadow-proxy.php [L,NC]
RewriteCond /var/www/html/lawangsewu/runtime-flags/widget-directory-shadow-on.flag -f
RewriteRule ^widget-links/?$ widget-directory-shadow-proxy.php [L,NC]
RewriteRule ^daftar-widget/?$ Walkthrough-DBPrakom/widget-links.html [L,NC]
RewriteRule ^widget-links/?$ Walkthrough-DBPrakom/widget-links.html [L,NC]
RewriteRule ^walkthrough/master-pdf/?$ Walkthrough-DBPrakom/pdf/Walkthrough-DBPrakom-Master.pdf [L,NC]
RewriteRule ^walkthrough/(md|pdf|html)/(.*)$ Walkthrough-DBPrakom/$1/$2 [L,NC]

# Public widget family shadow for safe canonical routes
RewriteCond /var/www/html/lawangsewu/runtime-flags/public-widget-shadow-on.flag -f
RewriteRule ^(info-persidangan|info-persidangan-hijautua|info-persidangan-stabilo|monitor-persidangan|antrian-persidangan|dashboard-perkara|dashboard-ecourt|dashboard-hakim|widget-pengumuman|berita-pengadilan|pengumuman-peradilan|pengumuman-peradilan-embed|panduan-embed-pengumuman|bridge-server10|radius-ghaib|radius-kecamatan|monitor-wa)/?$ public-widget-shadow-proxy.php [L,NC]
RewriteCond /var/www/html/lawangsewu/runtime-flags/landing-shadow-on.flag -f
RewriteRule ^$ landing-shadow-proxy.php [L,NC]
RewriteCond /var/www/html/lawangsewu/runtime-flags/portal-shadow-on.flag -f
RewriteRule ^portal(?:/launch)?/?$ portal-shadow-proxy.php [L,NC]
RewriteCond /var/www/html/lawangsewu/runtime-flags/app-registry-shadow-on.flag -f
RewriteRule ^app-registry(?:/launch)?/?$ app-registry-shadow-proxy.php [L,NC]

# Canonical alias redirects for public branding on the final domain
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^pa-semarang-pengumuman$ /pengumuman-peradilan [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^pa-semarang-pengumuman-embed$ /pengumuman-peradilan-embed [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^pengumuman-rss-widget$ /widget-pengumuman [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^pa-semarang-embed-snippet$ /panduan-embed-pengumuman [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^antrian-sidang$ /antrian-persidangan [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^monitor-antrian-sidang$ /monitor-persidangan [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^statistik-perkara$ /dashboard-perkara [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^statistik-ecourt$ /dashboard-ecourt [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^statistik-hakim$ /dashboard-hakim [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^biaya-proses-berperkara$ /biaya-perkara [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^biaya-radius-ghaib$ /radius-ghaib [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^tabel-radius-kecamatan$ /radius-kecamatan [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^server10-data$ /bridge-server10 [R=301,L,NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^wa-v2/qr$ /monitor-wa [R=301,L,NC]

# Public endpoint mapping -> implementasi internal widgets/views
RewriteRule ^$ widgets/views/php/public/landing.php [L,NC]
RewriteRule ^portal/?$ widgets/views/php/public/index.php [L,NC]
RewriteRule ^info-persidangan$ widgets/views/php/public/info-persidangan.php [L,NC]
RewriteRule ^info-persidangan-hijautua$ widgets/views/php/public/info-persidangan-hijautua.php [L,NC]
RewriteRule ^info-persidangan-stabilo$ widgets/views/php/public/info-persidangan-stabilo.php [L,NC]
RewriteRule ^monitor-persidangan$ widgets/views/php/public/monitor-antrian-sidang.php [L,NC]
RewriteRule ^monitor-antrian-sidang$ widgets/views/php/public/monitor-antrian-sidang.php [L,NC]
RewriteRule ^antrian-persidangan$ widgets/views/php/public/antrian-sidang.php [L,NC]
RewriteRule ^antrian-sidang$ widgets/views/php/public/antrian-sidang.php [L,NC]
RewriteRule ^antrian_controller$ widgets/views/php/system/antrian_controller.php [L,NC]
RewriteRule ^generate_slide$ widgets/views/php/system/generate_slide.php [L,NC]
RewriteRule ^dashboard-perkara$ widgets/views/php/public/statistik-perkara.php [L,NC]
RewriteRule ^statistik-perkara$ widgets/views/php/public/statistik-perkara.php [L,NC]
RewriteRule ^statistik-perkara-data$ widgets/views/php/api/statistik-data.php [L,NC]
RewriteRule ^statistik-data$ widgets/views/php/api/statistik-data.php [L,NC]
RewriteRule ^dashboard-ecourt$ widgets/views/php/public/statistik-ecourt.php [L,NC]
RewriteRule ^statistik-ecourt$ widgets/views/php/public/statistik-ecourt.php [L,NC]
RewriteRule ^dashboard-hakim$ widgets/views/php/public/statistik-hakim.php [L,NC]
RewriteRule ^statistik-hakim$ widgets/views/php/public/statistik-hakim.php [L,NC]
RewriteRule ^api/pengumuman-rss/?$ widgets/views/php/api/api-pengumuman-rss.php [L,NC,QSA]
RewriteRule ^api/pengumuman-rss/(ma|badilag|pta)/?$ widgets/views/php/api/api-pengumuman-rss.php?source=$1 [L,NC,QSA]
RewriteRule ^api/pengumuman/?$ widgets/views/php/api/api-pengumuman-rss.php [L,NC,QSA]
RewriteRule ^api/pengumuman/(ma|badilag|pta)/?$ widgets/views/php/api/api-pengumuman-rss.php?source=$1 [L,NC,QSA]
RewriteRule ^api/server10/?$ widgets/views/php/api/api-server10.php [L,NC,QSA]
RewriteRule ^api/server10/health/?$ widgets/views/php/api/api-server10.php?mode=health [L,NC,QSA]
RewriteRule ^api/server10/capabilities/?$ widgets/views/php/api/api-server10.php?mode=capabilities [L,NC,QSA]
RewriteRule ^api/wa-v2/?$ widgets/views/php/api/api-wa-v2.php [L,NC,QSA]
RewriteRule ^api/wa-v2/(health|qr|send-text|restart|disconnect)/?$ widgets/views/php/api/api-wa-v2.php?path=$1 [L,NC,QSA]
RewriteRule ^wa-v2/qr$ widgets/views/html/public/wa-v2-qr-viewer.html [L,NC]
RewriteRule ^widget-pengumuman$ widgets/views/php/public/widget-pengumuman-rss.php [L,NC]
RewriteRule ^pengumuman-rss-widget$ widgets/views/php/public/widget-pengumuman-rss.php [L,NC]
RewriteRule ^berita-pengadilan$ widgets/views/html/public/berita-pengadilan.html [L,NC]
RewriteRule ^biaya-perkara$ widgets/views/html/public/biaya-proses-berperkara.html [L,NC]
RewriteRule ^biaya-proses-berperkara$ widgets/views/html/public/biaya-proses-berperkara.html [L,NC]
RewriteRule ^pengumuman-peradilan$ widgets/views/php/public/pa-semarang-pengumuman.php [L,NC]
RewriteRule ^pa-semarang-pengumuman$ widgets/views/php/public/pa-semarang-pengumuman.php [L,NC]
RewriteRule ^pengumuman-peradilan-embed$ widgets/views/php/public/pa-semarang-pengumuman-embed.php [L,NC]
RewriteRule ^pa-semarang-pengumuman-embed$ widgets/views/php/public/pa-semarang-pengumuman-embed.php [L,NC]
RewriteRule ^panduan-embed-pengumuman$ widgets/views/html/public/pa-semarang-embed-snippet.html [L,NC]
RewriteRule ^pa-semarang-embed-snippet$ widgets/views/html/public/pa-semarang-embed-snippet.html [L,NC]
RewriteRule ^bridge-server10$ widgets/views/html/public/server10-data-app.html [L,NC]
RewriteRule ^server10-data$ widgets/views/html/public/server10-data-app.html [L,NC]
RewriteRule ^radius-ghaib$ widgets/views/php/public/biaya-radius-ghaib.php [L,NC]
RewriteRule ^biaya-radius-ghaib$ widgets/views/php/public/biaya-radius-ghaib.php [L,NC]
RewriteRule ^radius-kecamatan$ widgets/views/php/public/tabel-radius-kecamatan.php [L,NC]
RewriteRule ^tabel-radius-kecamatan$ widgets/views/php/public/tabel-radius-kecamatan.php [L,NC]
RewriteRule ^monitor-wa$ widgets/views/html/public/wa-v2-qr-viewer.html [L,NC]
RewriteRule ^tes$ widgets/views/php/public/tes.php [L,NC]

# 1a. URL KANONIK: PAKSA .php -> tanpa .php (hanya request asli dari browser)
RewriteCond %{THE_REQUEST} \.php[\s?] [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?lawangsewu\.pa-semarang\.go\.id$ [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# 1b. INTERNAL REWRITE: tanpa .php -> file .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# developed by zhayyn™

# 2. MEMBUNUH CACHE SECARA PAKSA DARI JANTUNG SERVER
<FilesMatch "\.(php|html|css|js)$">
    FileETag None
    <IfModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </IfModule>
</FilesMatch>
# 3. Pasang Iframe cuyyyyyyyyyyyyyyy
Header set Content-Security-Policy "frame-ancestors 'self' https://pa-semarang.go.id https://*.pa-semarang.go.id;"
