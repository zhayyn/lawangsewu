# developed by zhayyn™

# 1. MENGHILANGKAN EXTENSION .PHP DI URL
RewriteEngine On

# 0. HARDENING: blok akses langsung ke folder/file sensitif
RewriteRule ^(?:scripts|projects|logs|server10/archive|pasarjohar/php-arsip|gateway/data)(?:/|$) - [F,L,NC]
RewriteRule (^|/)\.(?!well-known/).* - [F,L,NC]
RewriteRule (^|/)(?:backup\.conf|offsite\.conf|\.env(?:\..*)?)$ - [F,L,NC]

# Sembunyikan implementasi internal: blok akses URL langsung ke widgets/views
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?widgets/views/ [NC]
RewriteRule ^widgets/views/ - [F,L,NC]

# Legacy URL compatibility for moved HTML files
RewriteRule ^agenda-kegiatan\.html$ widgets/views/agenda-kegiatan.html [L,NC]
RewriteRule ^slide_sidang\.html$ widgets/views/slide_sidang.html [L,NC]

# Public endpoint mapping -> implementasi internal widgets/views
RewriteRule ^$ widgets/views/index.php [L,NC]
RewriteRule ^info-persidangan$ widgets/views/info-persidangan.php [L,NC]
RewriteRule ^info-persidangan-hijautua$ widgets/views/info-persidangan-hijautua.php [L,NC]
RewriteRule ^info-persidangan-stabilo$ widgets/views/info-persidangan-stabilo.php [L,NC]
RewriteRule ^monitor-antrian-sidang$ widgets/views/monitor-antrian-sidang.php [L,NC]
RewriteRule ^antrian_controller$ widgets/views/antrian_controller.php [L,NC]
RewriteRule ^generate_slide$ widgets/views/generate_slide.php [L,NC]
RewriteRule ^tes$ widgets/views/tes.php [L,NC]

# 1a. URL KANONIK: PAKSA .php -> tanpa .php (hanya request asli dari browser)
RewriteCond %{THE_REQUEST} \.php[\s?] [NC]
RewriteRule ^(.+)\.php$ /lawangsewu/$1 [R=301,L]

# 1b. INTERNAL REWRITE: tanpa .php -> file .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# developed by zhayyn™

# 2. MEMBUNUH CACHE SECARA PAKSA DARI JANTUNG SERVER
<FilesMatch "\.(php|html|css|js)$">
    FileETag None
    <IfModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </IfModule>
</FilesMatch>
# 3. Pasang Iframe cuyyyyyyyyyyyyyyy
Header set Content-Security-Policy "frame-ancestors 'self' https://pa-semarang.go.id https://*.pa-semarang.go.id;"
