# developed by zhayyn™

# 1. MENGHILANGKAN EXTENSION .PHP DI URL
RewriteEngine On

# 0a. Compatibility: pada vhost lawangsewu.pa-semarang.go.id, beberapa link lama
# masih memakai prefix /lawangsewu/... Padahal DocumentRoot sudah langsung ke
# /var/www/html/lawangsewu. Strip prefix ini secara internal agar URL lama dan
# baru sama-sama hidup.
RewriteRule ^lawangsewu/(.*)$ $1 [L,NC]

# 0. HARDENING: blok akses langsung ke folder/file sensitif
RewriteRule ^(?:scripts|projects|logs|pasarjohar/php-arsip|pasarjohar/server10/archive|gateway/data)(?:/|$) - [F,L,NC]
RewriteRule (^|/)\.(?!well-known/).* - [F,L,NC]
RewriteRule (^|/)(?:backup\.conf|offsite\.conf|\.env(?:\..*)?)$ - [F,L,NC]

# Sembunyikan implementasi internal: blok akses URL langsung ke widgets/views
RewriteCond %{THE_REQUEST} \s+/(?:lawangsewu/)?widgets/views/ [NC]
RewriteRule ^widgets/views/ - [F,L,NC]

# Legacy URL compatibility for moved HTML files
RewriteRule ^agenda-kegiatan\.html$ widgets/views/agenda-kegiatan.html [L,NC]
RewriteRule ^slide_sidang\.html$ widgets/views/slide_sidang.html [L,NC]

# Public endpoint mapping -> implementasi internal widgets/views
RewriteRule ^$ widgets/views/index.php [L,NC]
RewriteRule ^info-persidangan$ widgets/views/info-persidangan.php [L,NC]
RewriteRule ^info-persidangan-hijautua$ widgets/views/info-persidangan-hijautua.php [L,NC]
RewriteRule ^info-persidangan-stabilo$ widgets/views/info-persidangan-stabilo.php [L,NC]
RewriteRule ^monitor-antrian-sidang$ widgets/views/monitor-antrian-sidang.php [L,NC]
RewriteRule ^antrian-sidang$ widgets/views/antrian-sidang.php [L,NC]
RewriteRule ^antrian_controller$ widgets/views/antrian_controller.php [L,NC]
RewriteRule ^generate_slide$ widgets/views/generate_slide.php [L,NC]
RewriteRule ^statistik-perkara$ widgets/views/statistik-perkara.php [L,NC]
RewriteRule ^statistik-perkara-data$ widgets/views/statistik-data.php [L,NC]
RewriteRule ^statistik-data$ widgets/views/statistik-data.php [L,NC]
RewriteRule ^statistik-ecourt$ widgets/views/statistik-ecourt.php [L,NC]
RewriteRule ^statistik-hakim$ widgets/views/statistik-hakim.php [L,NC]
RewriteRule ^api/pengumuman-rss/?$ widgets/views/api-pengumuman-rss.php [L,NC,QSA]
RewriteRule ^api/pengumuman-rss/(ma|badilag|pta)/?$ widgets/views/api-pengumuman-rss.php?source=$1 [L,NC,QSA]
RewriteRule ^api/pengumuman/?$ widgets/views/api-pengumuman-rss.php [L,NC,QSA]
RewriteRule ^api/pengumuman/(ma|badilag|pta)/?$ widgets/views/api-pengumuman-rss.php?source=$1 [L,NC,QSA]
RewriteRule ^api/server10/?$ widgets/views/api-server10.php [L,NC,QSA]
RewriteRule ^api/server10/health/?$ widgets/views/api-server10.php?mode=health [L,NC,QSA]
RewriteRule ^api/server10/capabilities/?$ widgets/views/api-server10.php?mode=capabilities [L,NC,QSA]
RewriteRule ^api/wa-v2/?$ widgets/views/api-wa-v2.php [L,NC,QSA]
RewriteRule ^api/wa-v2/(health|qr|send-text|restart|disconnect)/?$ widgets/views/api-wa-v2.php?path=$1 [L,NC,QSA]
RewriteRule ^wa-v2/qr$ widgets/views/wa-v2-qr-viewer.html [L,NC]
RewriteRule ^pengumuman-rss-widget$ widgets/views/widget-pengumuman-rss.php [L,NC]
RewriteRule ^berita-pengadilan$ widgets/views/berita-pengadilan.html [L,NC]
RewriteRule ^biaya-proses-berperkara$ widgets/views/biaya-proses-berperkara.html [L,NC]
RewriteRule ^pa-semarang-pengumuman$ widgets/views/pa-semarang-pengumuman.php [L,NC]
RewriteRule ^pa-semarang-pengumuman-embed$ widgets/views/pa-semarang-pengumuman-embed.php [L,NC]
RewriteRule ^pa-semarang-embed-snippet$ widgets/views/pa-semarang-embed-snippet.html [L,NC]
RewriteRule ^server10-data$ widgets/views/server10-data-app.html [L,NC]
RewriteRule ^biaya-radius-ghaib$ widgets/views/biaya-radius-ghaib.php [L,NC]
RewriteRule ^tabel-radius-kecamatan$ widgets/views/tabel-radius-kecamatan.php [L,NC]
RewriteRule ^tes$ widgets/views/tes.php [L,NC]

# 1a. URL KANONIK: PAKSA .php -> tanpa .php (hanya request asli dari browser)
RewriteCond %{THE_REQUEST} \.php[\s?] [NC]
RewriteRule ^(.+)\.php$ /lawangsewu/$1 [R=301,L]

# 1b. INTERNAL REWRITE: tanpa .php -> file .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# developed by zhayyn™

# 2. MEMBUNUH CACHE SECARA PAKSA DARI JANTUNG SERVER
<FilesMatch "\.(php|html|css|js)$">
    FileETag None
    <IfModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </IfModule>
</FilesMatch>
# 3. Pasang Iframe cuyyyyyyyyyyyyyyy
Header set Content-Security-Policy "frame-ancestors 'self' https://pa-semarang.go.id https://*.pa-semarang.go.id;"
