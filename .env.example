# Portable config untuk widgets/views
# Salin ke /var/www/html/lawangsewu/.env jika ingin override global

LW_SIPP_BASE_URL="https://sipp.pa-semarang.go.id"
# LW_SIPP_SLIDE_URL="https://sipp.pa-semarang.go.id/slide_sidang"
# LW_SIPP_SEARCH_URL="https://sipp.pa-semarang.go.id/?s="

# LW_SLIDE_LOCAL_FILE="/var/www/html/lawangsewu/widgets/views/slide_sidang.html"
# LW_LOG_FILE="/var/www/html/lawangsewu/logs/antrian_controller.log"

# Node gateway (proxy pengumuman)
# LW_NODE_GATEWAY_BASE="http://127.0.0.1:8787"
# LW_NODE_GATEWAY_FALLBACK_BASE="http://127.0.0.1:8788"

# WA v2 proxy (opsional hardening)
# LW_WA_V2_BASE="http://127.0.0.1:8790"
# LW_WA_V2_TOKEN="isi-token-rahasia"

# Bridge ke Server 10
# LW_SERVER10_BASE_URL="http://192.168.88.10"
# LW_SERVER10_TOKEN=""
# LW_SERVER10_TIMEOUT="15"
# LW_SERVER10_RETRIES="2"
# LW_SERVER10_LOG_FILE="/var/www/html/lawangsewu/logs/server10-bridge.log"
# LW_SERVER10_ALLOWED_PATHS="/lumpiapasar/panjar/_panjar_data_wilayah.php,/lumpiapasar/panjar/_cerai_proses.php,/lumpiapasar/api.php,/api/data"

# Standalone statistik perkara (single-file)
